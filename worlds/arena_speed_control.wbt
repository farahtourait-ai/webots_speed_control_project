#VRML_SIM R2025a utf8

WorldInfo {
  title "Speed Control Arena - FINAL CLEAN"
}

Viewpoint {
  orientation 1 0 0 -1.25
  position 0 4.5 4
  fieldOfView 0.8
}

Background {
  skyColor [0.7 0.75 0.8]
}

# ================= FLOOR (LIGHT WOOD COLOR - NO TEXTURE) =================
Solid {
  translation 0 0 -0.05
  children [
    Shape {
      geometry Box { size 6 6 0.05 }
      appearance PBRAppearance {
        baseColor 0.72 0.52 0.30
        roughness 0.5
      }
    }
  ]
  boundingObject Box { size 6 6 0.05 }
  physics NULL
}

# ================= WALLS =================
DEF WALL_APP PBRAppearance { baseColor 0.2 0.2 0.25 }

Solid {
  translation 0 -2.9 0.2
  children [ Shape { geometry Box { size 6 0.1 0.4 } appearance USE WALL_APP } ]
  boundingObject Box { size 6 0.1 0.4 }
}

Solid {
  translation 0 2.9 0.2
  children [ Shape { geometry Box { size 6 0.1 0.4 } appearance USE WALL_APP } ]
  boundingObject Box { size 6 0.1 0.4 }
}

Solid {
  translation -2.9 0 0.2
  children [ Shape { geometry Box { size 0.1 6 0.4 } appearance USE WALL_APP } ]
  boundingObject Box { size 0.1 6 0.4 }
}

Solid {
  translation 2.9 0 0.2
  children [ Shape { geometry Box { size 0.1 6 0.4 } appearance USE WALL_APP } ]
  boundingObject Box { size 0.1 6 0.4 }
}

# ================= LIGHT =================
DirectionalLight {
  direction 0.5 -1 -0.3
  intensity 0.9
}

# ================= OBSTACLES =================
DEF OBS_APP PBRAppearance { baseColor 0.15 0.15 0.18 }

Solid {
  translation 1.2 0 0.08
  children [ Shape { geometry Box { size 0.25 0.25 0.16 } appearance USE OBS_APP } ]
  boundingObject Box { size 0.25 0.25 0.16 }
}

Solid {
  translation -1.3 1.3 0.08
  children [ Shape { geometry Box { size 0.22 0.22 0.16 } appearance USE OBS_APP } ]
  boundingObject Box { size 0.22 0.22 0.16 }
}

Solid {
  translation 1.5 -1.3 0.08
  children [ Shape { geometry Cylinder { radius 0.13 height 0.16 } appearance USE OBS_APP } ]
  boundingObject Cylinder { radius 0.13 height 0.16 }
}

Solid {
  translation -1.2 -1.2 0.08
  children [ Shape { geometry Cylinder { radius 0.12 height 0.16 } appearance USE OBS_APP } ]
  boundingObject Cylinder { radius 0.12 height 0.16 }
}

Solid {
  translation 1.3 1.2 0.08
  children [ Shape { geometry Box { size 0.2 0.2 0.14 } appearance USE OBS_APP } ]
  boundingObject Box { size 0.2 0.2 0.14 }
}

# ================= ROBOT =================
Robot {
  translation 0 0 0
  children [

    # Body
    Shape {
      appearance PBRAppearance { baseColor 0.95 0.95 0.95 }
      geometry Cylinder { height 0.08 radius 0.09 }
    }

    # Left Wheel
    HingeJoint {
      jointParameters HingeJointParameters { axis 0 1 0 anchor 0 0.09 0.04 }
      device [ RotationalMotor { name "left wheel motor" } ]
      endPoint Solid {
        translation 0 0.09 0.04
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { height 0.02 radius 0.035 }
          }
        ]
        boundingObject Cylinder { height 0.02 radius 0.035 }
        physics Physics { mass 0.05 }
      }
    }

    # Right Wheel
    HingeJoint {
      jointParameters HingeJointParameters { axis 0 1 0 anchor 0 -0.09 0.04 }
      device [ RotationalMotor { name "right wheel motor" } ]
      endPoint Solid {
        translation 0 -0.09 0.04
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.1 0.1 0.1 }
            geometry Cylinder { height 0.02 radius 0.035 }
          }
        ]
        boundingObject Cylinder { height 0.02 radius 0.035 }
        physics Physics { mass 0.05 }
      }
    }

    # Distance Sensor
    DistanceSensor {
      translation 0.1 0 0.08
      name "ds_front"
      lookupTable [0 0 0, 0.5 500 0, 1 1000 0]
    }
  ]

  controller "speed_control"
  boundingObject Cylinder { height 0.08 radius 0.09 }
  physics Physics { mass 0.6 }
}
