#VRML_SIM R2025a utf8

WorldInfo {
  title "Speed Control Arena"
}
Viewpoint {
  orientation -0.23 -0.01 0.97 3.24
  position 2.7 0.1 1.6
}

# Simple Floor
Solid {
  translation 0 0 -0.05
  children [
    Shape {
      geometry Box { size 4 4 0.05 }
      appearance PBRAppearance { baseColor 0.8 0.8 0.8 roughness 0.8 }
    }
  ]
  boundingObject Box { size 4 4 0.05 }
  name "floor"
}

# Wall - Bottom
Solid {
  translation 0 -2 0.1
  children [
    Shape {
      geometry Box { size 4 0.1 0.2 }
      appearance PBRAppearance { baseColor 0.5 0.5 0.5 }
    }
  ]
  boundingObject Box { size 4 0.1 0.2 }
  physics NULL
  name "wall_bottom"
}

# Wall - Top
Solid {
  translation 0 2 0.1
  children [
    Shape {
      geometry Box { size 4 0.1 0.2 }
      appearance PBRAppearance { baseColor 0.5 0.5 0.5 }
    }
  ]
  boundingObject Box { size 4 0.1 0.2 }
  physics NULL
  name "wall_top"
}

# Wall - Left
Solid {
  translation -2 0 0.1
  children [
    Shape {
      geometry Box { size 0.1 4 0.2 }
      appearance PBRAppearance { baseColor 0.5 0.5 0.5 }
    }
  ]
  boundingObject Box { size 0.1 4 0.2 }
  physics NULL
  name "wall_left"
}

# Wall - Right
Solid {
  translation 2 0 0.1
  children [
    Shape {
      geometry Box { size 0.1 4 0.2 }
      appearance PBRAppearance { baseColor 0.5 0.5 0.5 }
    }
  ]
  boundingObject Box { size 0.1 4 0.2 }
  physics NULL
  name "wall_right"
}

# Obstacle 1 - RED (in front of robot at 0.6m)
Solid {
  translation 0.6 0 0.05
  children [
    Shape {
      geometry Box { size 0.15 0.15 0.1 }
      appearance PBRAppearance { baseColor 1 0 0 roughness 0.5 }
    }
  ]
  boundingObject Box { size 0.15 0.15 0.1 }
  physics NULL
  name "obstacle_red"
}

# Obstacle 2 - GREEN (right side)
Solid {
  translation 0.8 -0.8 0.05
  children [
    Shape {
      geometry Box { size 0.12 0.12 0.1 }
      appearance PBRAppearance { baseColor 0 1 0 roughness 0.5 }
    }
  ]
  boundingObject Box { size 0.12 0.12 0.1 }
  physics NULL
  name "obstacle_green"
}

# Obstacle 3 - BLUE (left side)
Solid {
  translation -0.8 0.5 0.05
  children [
    Shape {
      geometry Box { size 0.12 0.12 0.1 }
      appearance PBRAppearance { baseColor 0 0 1 roughness 0.5 }
    }
  ]
  boundingObject Box { size 0.12 0.12 0.1 }
  physics NULL
  name "obstacle_blue"
}

# Obstacle 4 - YELLOW (far back)
Solid {
  translation -0.5 -0.9 0.05
  children [
    Shape {
      geometry Box { size 0.12 0.12 0.1 }
      appearance PBRAppearance { baseColor 1 1 0 roughness 0.5 }
    }
  ]
  boundingObject Box { size 0.12 0.12 0.1 }
  physics NULL
  name "obstacle_yellow"
}

# ROBOT
DEF ROBOT1 Robot {
  translation 0 0 0
  rotation 0 0 -1 0
  children [
    # Main Body
    DEF MAIN_BODY Pose {
      translation 0 0 0.0415
      children [
        Shape {
          appearance PBRAppearance {
            baseColor 0.1 0.3 0.8
            roughness 0.5
          }
          geometry Cylinder { height 0.08 radius 0.045 }
        }
      ]
    }
    
    # Left Wheel Joint
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor 0 0.045 0.025
      }
      device [
        RotationalMotor { name "left wheel motor" }
      ]
      endPoint Solid {
        translation 0 0.045 0.025
        name "left_wheel_solid"
        children [
          DEF LEFT_WHEEL Shape {
            appearance PBRAppearance { baseColor 0.2 0.2 0.2 }
            geometry Cylinder { height 0.01 radius 0.025 }
          }
        ]
        boundingObject Cylinder { height 0.01 radius 0.025 }
        physics Physics { density -1 mass 0.05 }
      }
    }
    
    # Right Wheel Joint
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor 0 -0.045 0.025
      }
      device [
        RotationalMotor { name "right wheel motor" }
      ]
      endPoint Solid {
        translation 0 -0.045 0.025
        name "right_wheel_solid"
        children [
          DEF RIGHT_WHEEL Shape {
            appearance PBRAppearance { baseColor 0.2 0.2 0.2 }
            geometry Cylinder { height 0.01 radius 0.025 }
          }
        ]
        boundingObject Cylinder { height 0.01 radius 0.025 }
        physics Physics { density -1 mass 0.05 }
      }
    }
    
    # Front Distance Sensor
    DistanceSensor {
      translation 0.05 0 0.045
      rotation 0 0 1 0
      name "ds_front"
      lookupTable [0 0 0, 0.5 500 0, 1.0 1000 0]
    }
    
    # Left Distance Sensor
    DistanceSensor {
      translation 0 0.05 0.045
      rotation 0 0 1 0.5
      name "ds_left"
      lookupTable [0 0 0, 0.5 500 0, 1.0 1000 0]
    }
    
    # Right Distance Sensor
    DistanceSensor {
      translation 0 -0.05 0.045
      rotation 0 0 1 -0.5
      name "ds_right"
      lookupTable [0 0 0, 0.5 500 0, 1.0 1000 0]
    }
  ]
  name "robot1"
  controller "speed_control"
  boundingObject Cylinder { height 0.08 radius 0.045 }
  physics Physics { density -1 mass 0.5 }
}
